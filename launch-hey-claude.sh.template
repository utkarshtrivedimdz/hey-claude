#!/bin/bash
# hey-claude launcher — GENERATED by scripts/setup.sh (paths substituted).
#
# Installed to the INTERNAL disk (~/Library/Application Support/hey-claude/) so
# launchd can always start it at login, then it waits for the repo's venv to
# become available before starting hey-claude. This makes auto-start survive the boot
# race when the repo + venv live on an external volume (e.g. /Volumes/...): the
# wait-loop is a no-op for internal installs and blocks until mount for external.
set -u

PY="__PYTHON__"
REPO="__REPO__"

# Wait up to ~5 min for the venv to appear (logs every 30s to StandardErrorPath).
i=0
while [ ! -x "$PY" ] && [ "$i" -lt 300 ]; do
  [ $((i % 30)) -eq 0 ] && echo "$(date '+%Y-%m-%d %H:%M:%S') hey-claude: waiting for venv at $PY" >&2
  sleep 1
  i=$((i + 1))
done

if [ ! -x "$PY" ]; then
  echo "$(date '+%Y-%m-%d %H:%M:%S') hey-claude: venv missing after 5 min; exiting for launchd KeepAlive retry" >&2
  exit 1
fi

cd "$REPO" || exit 1
echo "$(date '+%Y-%m-%d %H:%M:%S') hey-claude: venv found; starting hey-claude" >&2
exec "$PY" -m hey_claude
